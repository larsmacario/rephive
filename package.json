{
  "name": "rephive",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "rephive · mobile-first Workout-Tracker (Vite + React + TS, Capacitor-ready)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "ios:sync": "npm run build && npx cap sync ios",
    "ios:open": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor-community/bluetooth-le": "^8.2.0",
    "@capacitor-mlkit/barcode-scanning": "^8.1.0",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/network": "^8.0.1",
    "@capgo/capacitor-speech-recognition": "^8.1.3",
    "@emotion/is-prop-valid": "^1.4.0",
    "@supabase/supabase-js": "^2.106.2",
    "barcode-detector": "^3.2.0",
    "dexie": "^4.4.3",
    "framer-motion": "^12.40.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^5.5.7",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^3.2.6"
  }
}
